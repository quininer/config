#!/usr/bin/sh

cat << EOF
{
	"set-env": {
		"EDITOR": "helix",
		"SSH_SSH_ASKPASS": "$(which ksshaskpass)",
		"SSH_AUTH_SOCK": "$XDG_RUNTIME_DIR/ssh-agent.socket"
	},
	"push-path": [
		"$HOME/.local/bin",
		"$HOME/.cargo/bin"
	],
	"prompt": {
		"exe": "bwrap",
		"args": [
			"--die-with-parent",
			"--unshare-all",
			"--cap-drop", "ALL",
			"--ro-bind", "/", "/",
			"--",
			"starship",
			"prompt", "-s", "@status", "-w", "@width"
		]
	},
	"complete": {
		"exe": "fish-as-a-complete-engine",
		"args": ["-i", "@index"]
	},
	"alias": {
		"ls": ["eza"],
		"la": ["eza", "-hal"],
		"hx": ["helix"],
		"wget": ["curl", "-L", "-O", "-C", "-"]
	}
}
EOF
